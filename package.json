{
  "name": "keydex",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "pnpm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply d1-keydex-prod-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply d1-keydex-prod-db --remote",
    "db:migrate:preview": "wrangler d1 migrations apply --env preview d1-keydex-preview-db --remote",
    "db:studio:local": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
    "db:studio:preview": "source .drizzle.env && DB_ID='ca360968-b9c1-4a53-9626-d3a5925ea056' drizzle-kit studio",
    "db:studio:prod": "source .drizzle.env && DB_ID='cbbb18dc-7e32-4695-977c-2255e403e983' drizzle-kit studio",
    "icons": "lemon-lime-svgs"
  },
  "dependencies": {
    "captain-react-hooks": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.31",
    "lemon-lime-svgs": "^2.0.1",
    "motion": "^12.29.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.10.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.5",
    "@react-router/dev": "^7.10.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22.19.7",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "better-sqlite3": "^12.6.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.8",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.60.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b",
  "lemonLimeSvgs": {
    "inputDir": "other/svg-icons",
    "outputDir": "public/images/icons",
    "typesDir": "app/types",
    "spriteFilename": "sprite.svg",
    "typeFilename": "name.d.ts",
    "verbose": true,
    "generateReadme": false
  }
}
